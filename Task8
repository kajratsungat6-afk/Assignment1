#include <iostream>
using namespace std;

int n, k;
int a[100];

void gen(int pos) {
    if (pos == n) {
        for (int i = 0; i < n; i++) cout << a[i] << " ";
        cout << endl;
        return;
    }

    for (int i = 1; i <= k; i++) {
        a[pos] = i;
        gen(pos + 1);
    }
}

int main() {
    cin >> n >> k;
    gen(0);
}

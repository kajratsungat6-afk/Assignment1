#include <iostream>
#include <cctype>
using namespace std;

void reverseStrings(int n) {
    if (n == 0) return;

    string s;
    cin >> s;

    reverseStrings(n - 1);
    for (char c : s) {
        cout << (char)tolower(c);
    }
    cout << endl;
}

int main() {
    int n;
    cin >> n;
    reverseStrings(n);
}

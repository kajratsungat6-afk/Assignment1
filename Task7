#include <iostream>
using namespace std;

void fillSpiral(int** a, int t, int b, int l, int r, int& num) {
    if (t > b || l > r) return;

    for (int i = l; i <= r; i++) a[t][i] = num++;
    for (int i = t + 1; i <= b; i++) a[i][r] = num++;
    for (int i = r - 1; i >= l; i--) a[b][i] = num++;
    for (int i = b - 1; i > t; i--) a[i][l] = num++;

    fillSpiral(a, t + 1, b - 1, l + 1, r - 1, num);
}

int main() {
    int n;
    cin >> n;

    int** a = new int* [n];
    for (int i = 0; i < n; i++) a[i] = new int[n];

    int num = 1;
    fillSpiral(a, 0, n - 1, 0, n - 1, num);

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++)
            cout << a[i][j] << " ";
        cout << endl;
    }
}

#include <iostream>
using namespace std;

// рекурсивная функция
int sum(int arr[], int n) {
    if (n == 0) 
        return 0;
    return arr[n - 1] + sum(arr, n - 1);
}

int main() {
    int n;
    cin >> n;

    // динамический массив
    int* arr = new int[n];

    // ввод элементов
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    // вызов функции
    cout << sum(arr, n);

    // освобождение памяти
    delete[] arr;

    return 0;
}
